{
  "formTitle": "Kunden-Feedback",
  "version": "1.0.2",
  "fields": [
    {
      "id": "name",
      "label": "Name",
      "controlType": "textfield",
      "dataType": "string",
      "required": true
    },
    {
      "id": "age",
      "label": "Alter",
      "controlType": "spinner",
      "dataType": "int",
      "required": false
    },
    {
      "id": "rating",
      "label": "Bewertung",
      "controlType": "dropdown",
      "dataType": "string",
      "required": true,
      "options": ["Sehr gut", "Gut", "Befriedigend", "Ausreichend", "Mangelhaft"]
    },
    {
      "id": "newsletter",
      "label": "Newsletter abonnieren",
      "controlType": "checkbox",
      "dataType": "boolean",
      "required": false
    },
    {
      "id": "comment",
      "label": "Kommentar",
      "controlType": "textarea",
      "dataType": "string",
      "required": false
    }
  ]
}